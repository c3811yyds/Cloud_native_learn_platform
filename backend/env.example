# Cloud Native Learning Platform environment template
# Default values below are intended for Docker Compose deployment on a server.

# Basic configuration
SECRET_KEY=replace_with_random_flask_secret_key
JWT_SECRET_KEY=replace_with_random_jwt_secret_key
DATABASE_URL=mysql+pymysql://admin:admin@db:3306/cloud_native_learning_platform?charset=utf8mb4

# Redis connection
REDIS_URL=redis://redis:6379/0

# Storage directory inside backend container
UPLOAD_DIR=./storage

# AI provider key
SILICON_API_KEY=fill_your_silicon_api_key

# Email settings
MAIL_CONSOLE_FALLBACK=false
MAIL_SERVER=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_email_auth_code

# Optional admin bootstrap
ADMIN_INIT_EMAIL=
ADMIN_INIT_USERNAME=
ADMIN_INIT_PASSWORD=

# If you run the backend directly on the host instead of Docker Compose,
# replace DATABASE_URL and REDIS_URL with host addresses like:
# DATABASE_URL=mysql+pymysql://root:mysql@127.0.0.1:3306/cloud_native_learning_platform?charset=utf8mb4
# REDIS_URL=redis://127.0.0.1:6380/0

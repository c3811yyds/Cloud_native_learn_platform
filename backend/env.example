# Basic configuration
SECRET_KEY=fill_your_flask_secret_key
JWT_SECRET_KEY=fill_your_jwt_secret_key
DATABASE_URL=mysql+pymysql://root:mysql@127.0.0.1:3306/cloud_native_learning_platform?charset=utf8mb4

# Redis connection
REDIS_URL=redis://127.0.0.1:6380/0

# Local storage directory
UPLOAD_DIR=./storage

# AI provider key
SILICON_API_KEY=sk-fill-your-own-key

# Email settings
MAIL_CONSOLE_FALLBACK=false
MAIL_SERVER=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_email_auth_code

# Optional admin bootstrap
ADMIN_INIT_EMAIL=
ADMIN_INIT_USERNAME=
ADMIN_INIT_PASSWORD=

